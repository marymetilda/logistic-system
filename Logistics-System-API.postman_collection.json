{
  "info": {
    "name": "Logistics System API",
    "description": "Postman collection for Logistics Delivery Route Optimization Backend System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"password123\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user with email, password, and optional role (ADMIN, DISPATCHER, VIEWER)"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with email and password to get JWT token"
          }
        }
      ]
    },
    {
      "name": "Hubs",
      "item": [
        {
          "name": "Create Hub",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Main Distribution Center\",\n  \"code\": \"HUB001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/hubs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "hubs"]
            },
            "description": "Create a new hub (requires ADMIN or DISPATCHER role)"
          }
        },
        {
          "name": "Get All Hubs",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/hubs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "hubs"]
            },
            "description": "Get all hubs (requires authentication)"
          }
        },
        {
          "name": "Get Hub by ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/hubs/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "hubs", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "hub_id_here",
                  "description": "Hub ID (MongoDB ObjectId)"
                }
              ]
            },
            "description": "Get a specific hub by ID (requires authentication)"
          }
        }
      ]
    },
    {
      "name": "Routes",
      "item": [
        {
          "name": "Create Route",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromHub\": \"507f1f77bcf86cd799439011\",\n  \"toHub\": \"507f1f77bcf86cd799439012\",\n  \"distance\": 50,\n  \"travelTime\": 60,\n  \"fuelCost\": 100,\n  \"trafficLevel\": \"LOW\",\n  \"isBlocked\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/routes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "routes"]
            },
            "description": "Create a new route between two hubs (requires ADMIN or DISPATCHER role)"
          }
        },
        {
          "name": "Optimize Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"start\": \"507f1f77bcf86cd799439011\",\n  \"end\": \"507f1f77bcf86cd799439012\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/routes/optimize",
              "host": ["{{baseUrl}}"],
              "path": ["api", "routes", "optimize"]
            },
            "description": "Optimize route between two hubs using Dijkstra's algorithm. Provide start and end hub IDs (MongoDB ObjectId format)"
          }
        },
        {
          "name": "Recalculate Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"start\": \"507f1f77bcf86cd799439011\",\n  \"end\": \"507f1f77bcf86cd799439012\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/routes/recalculate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "routes", "recalculate"]
            },
            "description": "Recalculate route between two hubs. Provide start and end hub IDs (MongoDB ObjectId format)"
          }
        },
        {
          "name": "Toggle Block Route",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isBlocked\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/routes/:routeId/block",
              "host": ["{{baseUrl}}"],
              "path": ["api", "routes", ":routeId", "block"],
              "variable": [
                {
                  "key": "routeId",
                  "value": "route_id_here",
                  "description": "Route ID (MongoDB ObjectId)"
                }
              ]
            },
            "description": "Block or unblock a route (requires ADMIN or DISPATCHER role)"
          }
        },
        {
          "name": "Update Traffic Level",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trafficLevel\": \"HIGH\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/routes/:routeId/traffic",
              "host": ["{{baseUrl}}"],
              "path": ["api", "routes", ":routeId", "traffic"],
              "variable": [
                {
                  "key": "routeId",
                  "value": "route_id_here",
                  "description": "Route ID (MongoDB ObjectId)"
                }
              ]
            },
            "description": "Update traffic level for a route (LOW, MEDIUM, HIGH) (requires ADMIN or DISPATCHER role)"
          }
        },
        {
          "name": "Detect Cycles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/routes/cycles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "routes", "cycles"]
            },
            "description": "Detect cycles in the route graph"
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Top Fastest Routes",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/fastest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "fastest"]
            },
            "description": "Get top fastest routes (requires authentication)"
          }
        },
        {
          "name": "Traffic Distribution",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/traffic-distribution",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "traffic-distribution"]
            },
            "description": "Get traffic distribution across routes (requires ADMIN role)"
          }
        },
        {
          "name": "Route Status Summary",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/route-status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "route-status"]
            },
            "description": "Get route status summary (requires ADMIN role)"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string",
      "description": "JWT token from login response"
    }
  ]
}
